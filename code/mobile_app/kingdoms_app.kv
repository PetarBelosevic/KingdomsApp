#:kivy 2.0

<ResultsTable@GridLayout>:
    cols: 4
    spacing: dp(4)
    padding: dp(4)


<BaseBoxLayout@BoxLayout>:
    orientation: "vertical"
    spacing: dp(8)
    padding: dp(8)


<HorizontalGrid@GridLayout>:
    rows: 1
    spacing: dp(8)
    padding: dp(8)
    size_hint_y: None


<VerticalGrid@GridLayout>:
    cols: 1
    padding: dp(2)
    spacing: dp(2)


<BaseButton@Button>:
    font_size: "24sp"
    size_hint_y: None
    height: dp(48)
    

<BaseLabel>:
    font_size: "24sp"
    size_hint_y: None
    height: self.texture_size[1] + dp(20)
    text_size: self.width, None
    halign: "center"
    valign: "middle"


<LegendLabel@BaseLabel>:
    height: self.texture_size[1] + dp(4)
    padding: dp(4)
    spacing: dp(8)
    font_size: "20sp"
    valign: "top"


<LegendLabelLeft@LegendLabel>:
    size_hint_x: 0.25
    size_hint_y: 1
    halign: "right"


<LegendLabelRight@LegendLabel>:
    size_hint_x: 0.75
    halign: "left"


<BaseTextInput>:
    multiline: False
    halign: "center"
    valign: "center"
    font_size: "28sp"
    background_color: (0.65, 0.65, 0.65, 1)

# --------------------------------------------------

RootScreenManager:
    id: screen_manager
    
    StartScreen:
        name: "start"
    ImageMethodScreen:
        name: "image_method"
    DetectedBoardScreen:
        name: "detected_board"
    BoardModelScreen:
        name: "board_model"
    RoundResultsScreen:
        name: "round_results"

# --------------------------------------------------

<GameInfoPopup>:
    title: "Game Info"
    size_hint: 0.8, 0.8
    AnchorLayout:
        spacing: dp(8)
        padding: dp(8)
        BaseLabel:
            font_size: "20sp"
            text: "Kingdoms by Reiner Knizia is a tactical tile-placement game where players place castles and resource tiles on a grid to maximize gold over three rounds. Players must maximize the value of their castles in rows/columns while using hazards to decrease opponents' scores."

<WinnerPopup>:
    title: "Winner"
    size_hint: 0.6, 0.5
    on_dismiss: app.go_to("start", "left", app.clear_game)
    VerticalGrid:
        BaseLabel:
            id: winner_label
            text: app.winner
        BaseLabel:
            text: app.score
            font_name: "RobotoMono-Regular"


<SymbolsLegendPopup>:
    title: "Symbols Legend"
    size_hint: 0.84, 0.6
    ScrollView:
        do_scroll_x: False
        bar_width: dp(4)
        VerticalGrid:
            cols: 2
            spacing: dp(4), dp(2)
            size_hint_y: None
            height: self.minimum_height
            LegendLabelLeft:
                text: "r1-r4:"
            LegendLabelRight:
                text: "red castles levels 1-4 (red color)"
            LegendLabelLeft:
                text: "g1-g4:"
            LegendLabelRight:
                text: "green castles levels 1-4 (green color)"
            LegendLabelLeft:
                text: "b1-b4:"
            LegendLabelRight:
                text: "blue castles levels 1-4 (blue color)"
            LegendLabelLeft:
                text: "y1-y4:"
            LegendLabelRight:
                text: "yellow castles levels 1-4 (yellow color)"
            LegendLabelLeft:
                text: "1 to 6:"
            LegendLabelRight:
                text: "resource cards values 1-6 (light blue color)"
            LegendLabelLeft:
                text: "-6 to -1:"
            LegendLabelRight:
                text: "hazard cards values -6 to -1 (orange color)"
            LegendLabelLeft:
                text: "d:"
            LegendLabelRight:
                text: "dragon (purple color)"
            LegendLabelLeft:
                text: "gm:"
            LegendLabelRight:
                text: "gold mine (purple color)"
            LegendLabelLeft:
                text: "m:"
            LegendLabelRight:
                text: "mountain (purple color)"
            LegendLabelLeft:
                text: "w:"
            LegendLabelRight:
                text: "wizard (purple color)"
            LegendLabelLeft:
                text: "e:"
            LegendLabelRight:
                text: "empty (black color)"
        

# --------------------------------------------------

<StartScreen>:
    BaseBoxLayout:
        BaseLabel:
            text: "Welcome to Kingdoms by Reiner Knizia!"
        BaseButton:
            text: "Game Info"
            on_release: app.show_game_info()
        BaseButton:
            text: "New Game"
            on_release: app.start_new_game()
        BaseButton:
            text: "Analyze One Image"
            on_release: app.go_to("image_method", "left", app.clear_game)

# --------------------------------------------------

<ImageMethodScreen>:
    BaseBoxLayout:
        BaseLabel:
            text: app.score
            font_name: "RobotoMono-Regular"
        BaseLabel:
            text: "Choose how to provide an image"
        BaseButton:
            disabled: not app.android
            text: "Take New Photo"
            on_release: app.start_camera()
        BaseButton:
            disabled: not app.android
            text: "Load Existing Photo"
            on_release: app.start_gallery()
        BaseButton:
            text: app.back_button_text
            on_release: app.go_to("start", "right")

# --------------------------------------------------

<DetectedBoardScreen>:
    BaseBoxLayout:
        BaseLabel:
            text: "Detected Board"
        RotatableImage:
            id: board
            canvas.before:
                PushMatrix
                Scale:
                    x: self.rotation_scale
                    y: self.rotation_scale
                    origin: self.center
                Rotate:
                    angle: self.angle
                    origin: self.center
            canvas.after:
                PopMatrix
        BaseButton:
            text: "Back to Start"
            on_release: app.go_to("start", "right", app.clear_metadata)
        BaseButton:
            text: "Back"
            on_release: app.go_to("image_method", "right", app.clear_metadata)
        BaseButton:
            text: "Continue"
            on_release: app.go_to("board_model", "left", app.generate_board_model)

# --------------------------------------------------

<BoardModelScreen>:
    BaseBoxLayout:
        GridLayout:
			id: board_model
			cols: 6
			rows: 5
			spacing: dp(4)
            padding: dp(4)
        BaseButton:
            text: "Show Symbols Legend"
            on_release: app.show_symbols_legend()
        BaseButton:
            text: "Back to Start"
            on_release: app.go_to("start", "right", app.clear_game)
        BaseButton:
            text: "Back"
            on_release: app.go_to("detected_board", "right", app.show_image)
        BaseButton:
            text: "Continue"
            on_release: app.go_to("round_results", "left", app.calculate_scores)
# --------------------------------------------------

<RoundResultsScreen>:
    BaseBoxLayout:
        BaseLabel:
            text: "Round Results"
        ResultsTable:
            id: results_table
            BaseLabel:
                text: ""
            BaseLabel:
                text: "Total"
            BaseLabel:
                text: "Last Round"
            BaseLabel:
                text: "This round"
            BaseLabel:
                text: "Red"
            BaseLabel:
                text: app.red_total
            BaseLabel:
                text: app.red_last
            BaseLabel:
                text: app.red_new
            BaseLabel:
                text: "Green"
            BaseLabel:
                text: app.green_total
            BaseLabel:
                text: app.green_last
            BaseLabel:
                text: app.green_new
            BaseLabel:
                text: "Blue"
            BaseLabel:
                text: app.blue_total
            BaseLabel:
                text: app.blue_last
            BaseLabel:
                text: app.blue_new
            BaseLabel:
                text: "Yellow"
            BaseLabel:
                text: app.yellow_total
            BaseLabel:
                text: app.yellow_last
            BaseLabel:
                text: app.yellow_new
        BaseLabel:
            text: app.round
        BaseButton:
            text: "Back to Start"
            on_release: app.go_to("start", "right", app.clear_game)
        BaseButton:
            text: "Back to Board"
            on_release: app.go_to("board_model", "right", app.decrease_round)
        BaseButton:
            text: "Next"
            on_release: app.next_round()