#:kivy 2.0

<BaseBoxLayout@BoxLayout>:
    orientation: "vertical"
    spacing: dp(16)
    padding: dp(16)


<HorizontalGrid@GridLayout>:
    rows: 1
    spacing: dp(16)
    padding: dp(16)
    size_hint_y: None


<BaseButton@Button>:
    font_size: "24sp"
    size_hint_y: None
    height: dp(48)
    

<BaseLabel@Label>:
    font_size: "24sp"
    size_hint_y: None
    height: self.texture_size[1] + dp(20)
    text_size: self.width, None
    halign: "center"
    valign: "middle"


<BaseTextInput>:
    multiline: False
    halign: "center"
    valign: "center"
    font_size: "28sp"
    background_color: (0.65, 0.65, 0.65, 1)

# --------------------------------------------------

RootScreenManager:
    id: screen_manager
    
    StartScreen:
        name: "start"
    ImageMethodScreen:
        name: "image_method"
    # GalleryScreen:
    #     name: "gallery"
    DetectedBoardScreen:
        name: "detected_board"
    BoardModelScreen:
        name: "board_model"
    RoundResultsScreen:
        name: "round_results"

# --------------------------------------------------

<GameInfoPopup>:
    spacing: dp(16)
    padding: dp(16)
    BaseLabel:
        font_size: "20sp"
        text: "Kingdoms is a tile-laying game designed by Reiner Knizia. Players take turns placing tiles on a shared board, aiming to create and control kingdoms. Each tile has different terrain types, and players score points based on the size and composition of their kingdoms. The game combines strategic placement with tactical decision-making, making it a favorite among board game enthusiasts."


<WinnerPopup>:
    spacing: dp(16)
    padding: dp(16)
    BaseLabel:
        id: winner_label
        text: app.winner

# --------------------------------------------------

<StartScreen>:
    BaseBoxLayout:
        BaseLabel:
            text: "Welcome to Kingdoms by Reiner Knizia!"
        BaseButton:
            text: "Game Info"
            on_release: app.show_game_info()
        BaseButton:
            text: "New Game"
            on_release: app.start_new_game()
        BaseButton:
            text: "Analyze One Image"
            on_release: app.go_to("image_method", "left", app.clear_game)

# --------------------------------------------------

<ImageMethodScreen>:
    BaseBoxLayout:
        BaseLabel:
            text: "Choose how to provide an image"
        BaseButton:
            disabled: not app.android
            text: "Take New Photo"
            on_release: app.start_camera()
        BaseButton:
            disabled: not app.android
            text: "Load Existing Photo"
            on_release: app.start_gallery()
        BaseButton:
            text: "Back"
            on_release: app.go_to("start", "right")

# --------------------------------------------------

<GalleryScreen>:
    on_enter: app.load_gallery(); self.populate_thumbnails()
    
    gallery_grid: gallery_grid
    
    BaseBoxLayout:
        orientation: "vertical"
        spacing: dp(8)
        padding: dp(8)
        
        BaseLabel:
            size_hint_y: None
            height: dp(40)
            text: "Select Photo (newest 100)"
        
        ScrollView:
            GridLayout:
                id: gallery_grid
                cols: 4
                spacing: dp(8)
                size_hint_y: None
                height: self.minimum_height
        
        HorizontalGrid:
            BaseButton:
                text: "Select"
                on_release: app.use_selected_from_gallery()
            BaseButton:
                text: "Back"
                on_release: app.go_to("image_method", "right")


# --------------------------------------------------

<DetectedBoardScreen>:
    BaseBoxLayout:
        BaseLabel:
            text: "Detected Board"
        Image:
            id: board
        # HorizontalGrid:
        BaseButton:
            text: "Back to Start"
            on_release: app.go_to("start", "right", app.clear_metadata)
        BaseButton:
            text: "Back"
            on_release: app.go_to("image_method", "right", app.clear_metadata)
        BaseButton:
            text: "Continue"
            on_release: app.go_to("board_model", "left", app.generate_board_model)

# --------------------------------------------------

<BoardModelScreen>:
    BaseBoxLayout:
        GridLayout:
			id: board_model
			cols: 6
			rows: 5
			spacing: dp(4)
            padding: dp(4)
        BaseButton:
            text: "Back to Start"
            on_release: app.go_to("start", "right", app.clear_game)
        BaseButton:
            text: "Back"
            on_release: app.go_to("detected_board", "right", app.show_image)
        BaseButton:
            text: "Continue"
            on_release: app.go_to("round_results", "left", app.calculate_scores)
# --------------------------------------------------

<RoundResultsScreen>:
    BaseBoxLayout:
        BaseLabel:
            text: "Round Results"
        BaseLabel:
            text: app.score
            font_name: "RobotoMono-Regular"
        BaseLabel:
            text: app.round
        BaseButton:
            text: "Back to Start"
            on_release: app.go_to("start", "right", app.clear_game)
        BaseButton:
            text: "Back to Board"
            on_release: app.go_to("board_model", "right", app.decrease_round)
        BaseButton:
            text: "Next"
            on_release: app.next_round()